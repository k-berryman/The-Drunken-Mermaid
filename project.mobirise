3.709 152.527 155.931 154.23 157.297 155.247C158.662 156.263 160.027 157.304 161.382 158.236C163.524 159.688 165.666 161.139 167.858 162.472C170.328 163.958 172.816 165.426 175.409 166.663C177.7 167.679 180.042 168.575 182.426 169.347C182.586 169.403 182.757 169.425 182.926 169.413C183.636 169.399 184.312 169.106 184.807 168.597C185.103 168.202 185.507 167.902 185.971 167.733C186.435 167.564 186.938 167.535 187.419 167.648C187.628 167.73 187.813 167.861 187.96 168.031C188.106 168.2 188.209 168.403 188.259 168.622V168.622ZM135.163 135.831C135.135 135.074 135.066 134.319 134.955 133.57C134.446 131.132 131.56 122.616 130.55 120.948C129.176 118.628 127.578 116.45 125.778 114.442C124.903 113.391 123.949 112.409 122.922 111.506C122.183 110.921 121.243 110.65 120.306 110.75C119.368 110.851 118.508 111.316 117.909 112.045C117.21 112.937 117.252 113.792 117.671 115.434C118.296 117.595 119.381 119.594 120.851 121.296C125.069 125.936 134.578 135.339 135.193 135.801L135.163 135.831Z\">\n                            </path>\n                        </svg>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn {{alignButtons}}\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\">\n                            <a class=\"btn btn-size btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\"><strong>SUBSCRIBE</strong></a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-8\">\n                <div class=\"image-container\">\n                    <div class=\"image-inner-container\">\n                        <div class=\"image-col col-aside\">\n                            <div class=\"tile\">\n                                <div class=\"image-wrap\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/blue-and-yellow-beach-cocktail-400x400.jpg\" alt=\"Mobirise\">\n                                </div>\n                                <div class=\"mbr-description\">\n                                    <p class=\"mbr-description mbr-fonts-style mt-2\" mbr-theme-style=\"display-4\" mbr-if=\"showDescription\" data-app-selector=\".mbr-description\">\n                                        Image Description\n                                    </p>\n                                </div>\n                            </div>\n                            <div class=\"tile\">\n                                <div class=\"image-wrap\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/pink-beach-cocktail-fancy-glass-400x400.jpg\" alt=\"Mobirise\">\n                                </div>\n                                <div class=\"mbr-description\">\n                                    <p class=\"mbr-description mbr-fonts-style mt-2\" mbr-theme-style=\"display-4\" mbr-if=\"showDescription\" data-app-selector=\".mbr-description\">\n                                        Image Description\n                                    </p>\n                                </div>\n                            </div>\n                            <div class=\"tile\">\n                                <div class=\"image-wrap\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/beach-bar-drinks-with-them-on-the-right-so-theres-space-on-the-left.jpeg\" alt=\"Mobirise\">\n                                </div>\n                                <div class=\"mbr-description\">\n                                    <p class=\"mbr-description mbr-fonts-style mt-2\" mbr-theme-style=\"display-4\" mbr-if=\"showDescription\" data-app-selector=\".mbr-description\">\n                                        Image Description\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"image-col col-middle\">\n                            <div class=\"tile\">\n                                <div class=\"image-wrap\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/mother-daughter-business-owners-of-beach-bar-600x600.jpeg\" alt=\"Mobirise\">\n                                </div>\n                                <div class=\"mbr-description\">\n                                    <p class=\"mbr-description mbr-fonts-style mt-2\" mbr-theme-style=\"display-4\" mbr-if=\"showDescription\" data-app-selector=\".mbr-description\">\n                                        Image Description\n                                    </p>\n                                </div>\n                            </div>\n                            <div class=\"tile\">\n                                <div class=\"image-wrap\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/women-enjoying-cocktails-at-beach-bar-600x600.jpeg\" alt=\"Mobirise\">\n                                </div>\n                                <div class=\"mbr-description\">\n                                    <p class=\"mbr-description mbr-fonts-style mt-2\" mbr-theme-style=\"display-4\" mbr-if=\"showDescription\" data-app-selector=\".mbr-description\">\n                                        Image Description\n                                    </p>\n                                </div>\n                            </div>\n                            <div class=\"tile\">\n                                <div class=\"image-wrap\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/beach-bar-focus-on-the-drinks.jpeg\" alt=\"Mobirise\">\n                                </div>\n                                <div class=\"mbr-description\">\n                                    <p class=\"mbr-description mbr-fonts-style mt-2\" mbr-theme-style=\"display-4\" mbr-if=\"showDescription\" data-app-selector=\".mbr-description\">\n                                        Image Description\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"image-col col-aside\">\n                            <div class=\"tile\">\n                                <div class=\"image-wrap\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/green-beach-cocktail-400x400.jpg\" alt=\"Mobirise\">\n                                </div>\n                                <div class=\"mbr-description\">\n                                    <p class=\"mbr-description mbr-fonts-style mt-2\" mbr-theme-style=\"display-4\" mbr-if=\"showDescription\" data-app-selector=\".mbr-description\">\n                                        Image Description\n                                    </p>\n                                </div>\n                            </div>\n                            <div class=\"tile\">\n                                <div class=\"image-wrap\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/purple-beach-drink-cocktail-fancy-glass-400x400.jpg\" alt=\"Mobirise\">\n                                </div>\n                                <div class=\"mbr-description\">\n                                    <p class=\"mbr-description mbr-fonts-style mt-2\" mbr-theme-style=\"display-4\" mbr-if=\"showDescription\" data-app-selector=\".mbr-description\">\n                                        Image Description\n                                    </p>\n                                </div>\n                            </div>\n                            <div class=\"tile\">\n                                <div class=\"image-wrap\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/yellow-beach-cocktail-400x400.jpg\" alt=\"Mobirise\">\n                                </div>\n                                <div class=\"mbr-description\">\n                                    <p class=\"mbr-description mbr-fonts-style mt-2\" mbr-theme-style=\"display-4\" mbr-if=\"showDescription\" data-app-selector=\".mbr-description\">\n                                        Image Description\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "@media (max-width: 1199px)": {
              ".col-lg-4, .col-lg-8": {
                "width": "100%"
              }
            },
            ".text-wrapper": {
              "@media (max-width: 1199px)": {
                "text-align": "center",
                "margin-top": "50px"
              }
            },
            ".mbr-section-title": {
              "margin-bottom": "2.3rem",
              "span": {
                "position": "relative",
                "svg": {
                  "position": "absolute",
                  "top": "-30px",
                  "left": "-33px",
                  "width": "63px",
                  "height": "60px",
                  "transform": "rotate(275deg)",
                  "path": {
                    "fill": "@titleDecColor"
                  },
                  "& when not (@showTitle)": {
                    "display": "none"
                  },
                  "& when not (@addTitleDec)": {
                    "display": "none"
                  }
                }
              }
            },
            ".mbr-section-btn": {
              "margin-top": "83.4px",
              "@media (max-width: 1199px)": {
                "justify-content": "center!important"
              },
              "& when (@showButtons)": {
                "display": "flex",
                "flex-wrap": "wrap"
              },
              "& when not (@addBtnDec)": {
                "margin-top": "40px"
              }
            },
            ".button-container": {
              "position": "relative",
              "svg": {
                "position": "absolute",
                "top": "-65px",
                "left": "-50px",
                "width": "70px",
                "height": "75px",
                "@media (max-width: 1199px)": {
                  "left": "300px"
                },
                "@media (max-width: 991px)": {
                  "left": "200px"
                },
                "@media (max-width: 767px)": {
                  "left": "100px"
                },
                "@media (max-width: 519px)": {
                  "left": "90px"
                },
                "@media (max-width: 460px)": {
                  "left": "60px"
                },
                "@media (max-width: 359px)": {
                  "left": "0"
                },
                "path": {
                  "fill": "@btnDecColor"
                },
                "& when not (@showButtons)": {
                  "display": "none"
                },
                "& when not (@addBtnDec)": {
                  "display": "none"
                }
              }
            },
            ".image-container": {
              "height": "570px",
              "display": "flex",
              "justify-content": "flex-end",
              "overflow": "hidden",
              "@media (max-width: 1199px)": {
                "margin-top": "50px",
                "justify-content": "center"
              },
              "@media (max-width: 359px)": {
                "height": "490px"
              }
            },
            ".image-inner-container": {
              "display": "grid",
              "grid-template-columns": "200px 300px 200px",
              "grid-column-gap": "32px",
              "margin-top": "-150px",
              "@media (max-width: 1399px)": {
                "grid-column-gap": "14px"
              },
              "@media (max-width: 1199px)": {
                "grid-template-columns": "180px 280px 180px",
                "grid-column-gap": "28px",
                "margin-top": "0"
              }
            },
            ".tile": {
              "width": "100%",
              "margin-bottom": "16px",
              "img": {
                "width": "100%",
                "height": "100%",
                "object-fit": "cover"
              }
            },
            ".image-wrap": {
              "border-radius": "15px",
              "overflow": "hidden"
            },
            ".image-col": {
              "display": "flex",
              "flex-direction": "column",
              "align-items": "center"
            },
            ".col-aside": {
              "& when not (@showDescription)": {
                "padding-top": "60px"
              },
              ".image-wrap": {
                "height": "230px"
              }
            },
            ".col-middle": {
              "padding-top": "100px",
              "@media (max-width: 1199px)": {
                "padding-top": "50px",
                ".tile:last-child": {
                  "display": "none"
                }
              },
              "@media (max-width: 356px)": {
                "padding-top": "0"
              },
              "& when not (@showDescription)": {
                "padding-top": "165px"
              },
              ".image-wrap": {
                "height": "170px"
              }
            }
          },
          "_cid": "vd1Q7eUGV1",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "image2-n"
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".menu-item": {
              "padding": "0 1rem 1rem 1rem",
              ".special-label": {
                "display": "none"
              },
              "&.special-item": {
                "padding-bottom": "0",
                "margin-bottom": "1rem",
                "border": "2px solid @specialColor",
                ".special-label": {
                  "display": "block",
                  "width": "100%",
                  "word-break": "break-word",
                  ".label-text": {
                    "max-width": "100%",
                    "background": "@specialColor",
                    "padding": "0.5rem 1rem",
                    "display": "inline-block"
                  }
                }
              }
            },
            ".special-label": {
              "color": "#fff"
            },
            ".menu-box": {
              "display": "flex",
              "-webkit-justify-content": "space-between",
              "justify-content": "space-between",
              ".box-text": {
                "word-break": "break-word",
                "padding-right": "2rem",
                "width": "100%"
              },
              ".box-price": {
                "-webkit-flex-shrink": "0",
                "flex-shrink": "0"
              }
            },
            ".menu-row .menu-item:last-child": {
              "margin-bottom": "2rem"
            },
            ".menu-row": {
              "margin": "0"
            },
            ".group-title": {
              "color": "#009fce",
              "font-weight": "bold"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            }
          },
          "_name": "restaurant-menu2",
          "_sourceTheme": "restaurantm4",
          "_customHTML": "<section class=\"restaurant-menu2 restaurantm4_restaurant-menu2 restaurant-special-menu\" group=\"Restaurant Menu\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\" plugins=\"mbr-restaurant-special-menu\">\n\n\t<mbr-parameters>\n\t\t\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"3\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"3\">\n\t\t<input type=\"checkbox\" title=\"Show Title\" name=\"showTitle\" checked>\n\t\t<input type=\"checkbox\" title=\"Show Underline\" name=\"showUnderline\" checked>\n\t\t<input type=\"color\" title=\"Underlines Color\" name=\"underlineColor\" value=\"#009fce\" condition=\"showUnderline\">\n\n\t\t<input type=\"color\" title=\"Special Item\" name=\"specialColor\" value=\"#009fce\">\n\t\t<select title=\"Groups\" name=\"groups\">\n\t\t\t<option value=\"2\">2</option>\n\t\t\t<option value=\"3\" selected>3</option>\n\t\t\t<option value=\"4\">4</option>\n\t\t\t<option value=\"5\">5</option>\n\t\t\t<option value=\"6\">6</option>\n\t\t</select>\n\t\t<input type=\"range\" title=\"Group1 Items\" inline name=\"group1Items\" min=\"1\" max=\"50\" value=\"2\" step=\"1\">\n\t\t<input type=\"text\" title=\"Special Items In Group\" name=\"specialsInGroup1\" value=\"2\">\n\n\t\t<input type=\"range\" title=\"Group2 Items\" inline name=\"group2Items\" min=\"1\" max=\"50\" value=\"5\" step=\"1\">\n\t\t<input type=\"text\" title=\"Special Items In Group\" name=\"specialsInGroup2\" value=\"3;5\">\n\n\t\t<input type=\"range\" title=\"Group3 Items\" inline name=\"group3Items\" min=\"1\" max=\"50\" value=\"3\" step=\"1\" condition=\"groups >2\">\n\t\t<input type=\"text\" title=\"Special Items In Group\" name=\"specialsInGroup3\" value condition=\"groups>2\">\n\n\t\t<input type=\"range\" title=\"Group4 Items\" inline name=\"group4Items\" min=\"1\" max=\"50\" value=\"1\" step=\"1\" condition=\"groups >3\">\n\t\t<input type=\"text\" title=\"Special Items In Group\" name=\"specialsInGroup4\" value condition=\"groups>3\">\n\n\t\t<input type=\"range\" title=\"Group5 Items\" inline name=\"group5Items\" min=\"1\" max=\"50\" value=\"1\" step=\"1\" condition=\"groups >4\">\n\t\t<input type=\"text\" title=\"Special Items In Group\" name=\"specialsInGroup5\" value condition=\"groups>4\">\n\n\t\t<input type=\"range\" title=\"Group6 Items\" inline name=\"group6Items\" min=\"1\" max=\"50\" value=\"1\" step=\"1\" condition=\"groups >5\">\n\t\t<input type=\"text\" title=\"Special Items In Group\" name=\"specialsInGroup6\" value condition=\"groups>5\">\n\t\t<header>Background</header>\n\t\t<fieldset type=\"background\" name=\"bg\" parallax>\n\t\t\t<input type=\"image\" value=\"@PROJECT_PATH@/assets/images/beach-bar-food.jpg\" title=\"Image\" selected>\n\t\t\t<input type=\"color\" value=\"#ffffff\" title=\"Color\">\n\t\t\t<input type=\"video\" value=\"https://www.youtube.com/watch?v=pjiVuLVqWQg\" title=\"Video\">\n\t\t</fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n\n\t\t<input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n\t\t<input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n\t\t<input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n\t\t\n\t</mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n\n\t<div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n\t</div>\n\n\t<div class=\"container\">\n\t\t<h2 class=\"mbr-section-title align-center mbr-fonts-style mbr-black\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title,.ornament\">\n\t\t\tDiscover Our Menu\n\t\t</h2>\n\t\t<div class=\"py-3 ornament align-center\" mbr-if=\"showUnderline\">\n\t\t\t<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 133 20\" height=\"20\" width=\"150\" fill=\"{{underlineColor}}\">\n\t\t\t\t<g>\n\t\t\t\t\t<path d=\"M127.18,6.19C121-.05,109.94-.24,101.84.1,90.84.56,80,3.3,69.32,5.77c-8,1.86-16,3.63-24,5.72-9.21,2.41-18.6,4.72-28.14,5.19-4.1.2-8.48,0-12.16-2a6.6,6.6,0,0,1-2.7-9A5.46,5.46,0,0,1,7.07,2.77c4-.22,6.73,8.39-.08,4.58a.49.49,0,0,0-.49.84c4.88,3,10.8,0,5.4-4.91C7.6-.63.4,2.06,0,8-1,24,28.25,17,36.29,15.24,53.74,11.37,70.9,6.44,88.53,3.33c11.1-2,24.75-3.54,35.06,2.19a16,16,0,0,1,6.86,8.85c1.29,4.31-4.35,4.2-7,3.52-4.84-1.26-2.42-8,1.22-3,.61.83,2,0,1.4-.82-2.15-2.93-6.71-4.9-7.12.35s8.36,7.24,11.72,4.47C135,15.32,129.91,9,127.18,6.19Z\">\n\t\t\t\t\t</path>\n\t\t\t\t</g>\n\t\t\t</svg>\n\t\t</div>\n\n\t\t<div class=\"row\" mbr-class=\"{'pt-5':showTitle||showUnderline}\">\n\t\t\t<div class=\"col-md-6\">\n\t\t\t\t<div class=\"menu-group\">\n\t\t\t\t\t<h3 class=\"mbr-fonts-style group-title mbr-black align-left\" mbr-theme-style=\"display-2\" data-app-selector=\".group-title\">\n\t\t\t\t\t\tSoups\n\t\t\t\t\t</h3>\n\t\t\t\t\t<div class=\"row menu-row\" mbr-list mbr-list-grow=\"group1Items\" data-specials=\"{{specialsInGroup1}}\">\n\t\t\t\t\t\t<div class=\"col-md-12 menu-item\">\n\t\t\t\t\t\t\t<div class=\"special-label align-right\">\n\t\t\t\t\t\t\t\t<div mbr-text class=\"label-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".special-label\">Chef Selection</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<h3 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title\">Frito Pie</h3>\n\t\t\t\t\t\t\t<div class=\"menu-box\">\n\t\t\t\t\t\t\t\t<p class=\"box-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".box-text\">\n\t\t\t\t\t\t\t\t\tLorem ipsum dolor sit amet, consectetur\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t<span mbr-text class=\"mbr-fonts-style box-price mbr-black\" mbr-theme-style=\"display-2\">\n\t\t\t\t\t\t\t\t\t$3\n\t\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"col-md-12 menu-item\">\n\t\t\t\t\t\t\t<div class=\"special-label align-right\">\n\t\t\t\t\t\t\t\t<div mbr-text class=\"label-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".special-label\">New</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<h3 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title\">Belgian onion soup</h3>\n\t\t\t\t\t\t\t<div class=\"menu-box\">\n\t\t\t\t\t\t\t\t<p class=\"box-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".box-text\">\n\t\t\t\t\t\t\t\t\tLorem ipsum dolor sit amet, consectetur\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t<span mbr-text class=\"mbr-fonts-style box-price mbr-black\" mbr-theme-style=\"display-2\">\n\t\t\t\t\t\t\t\t\t$6\n\t\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"menu-group\" mbr-if=\"groups > 2\">\n\t\t\t\t\t<h3 class=\"mbr-fonts-style group-title mbr-black align-left\" mbr-theme-style=\"display-2\" data-app-selector=\".group-title\">\n\t\t\t\t\t\tSalads\n\t\t\t\t\t</h3>\n\t\t\t\t\t<div class=\"row menu-row\" mbr-list mbr-list-grow=\"group3Items\" data-specials=\"{{specialsInGroup3}}\">\n\t\t\t\t\t\t<div class=\"col-md-12 menu-item\">\n\t\t\t\t\t\t\t<div class=\"special-label align-right\">\n\t\t\t\t\t\t\t\t<div mbr-text class=\"label-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".special-label\">Chef Selection</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<h3 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title\">Greec Salad</h3>\n\t\t\t\t\t\t\t<div class=\"menu-box\">\n\t\t\t\t\t\t\t\t<p class=\"box-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".box-text\">\n\t\t\t\t\t\t\t\t\tLorem ipsum dolor sit amet, consectetur\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t<span mbr-text class=\"mbr-fonts-style box-price mbr-black\" mbr-theme-style=\"display-2\">\n\t\t\t\t\t\t\t\t\t$6\n\t\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"col-md-12 menu-item\">\n\t\t\t\t\t\t\t<div class=\"special-label align-right\">\n\t\t\t\t\t\t\t\t<div mbr-text class=\"label-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".special-label\">Chef Selection</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<h3 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title\">Ceasar Salad</h3>\n\t\t\t\t\t\t\t<div class=\"menu-box\">\n\t\t\t\t\t\t\t\t<p class=\"box-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".box-text\">\n\t\t\t\t\t\t\t\t\tLorem ipsum dolor sit amet, consectetur\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t<span mbr-text class=\"mbr-fonts-style box-price mbr-black\" mbr-theme-style=\"display-2\">\n\t\t\t\t\t\t\t\t\t$8\n\t\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"col-md-12 menu-item\">\n\t\t\t\t\t\t\t<div class=\"special-label align-right\">\n\t\t\t\t\t\t\t\t<div mbr-text class=\"label-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".special-label\">Chef Selection</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<h3 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title\">Crab Salad</h3>\n\t\t\t\t\t\t\t<div class=\"menu-box\">\n\t\t\t\t\t\t\t\t<p class=\"box-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".box-text\">\n\t\t\t\t\t\t\t\t\tLorem ipsum dolor sit amet, consectetur\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t<span mbr-text class=\"mbr-fonts-style box-price mbr-black\" mbr-theme-style=\"display-2\">\n\t\t\t\t\t\t\t\t\t$10\n\t\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"menu-group\" mbr-if=\"groups > 4\">\n\t\t\t\t\t<h3 class=\"mbr-fonts-style group-title mbr-black align-left\" mbr-theme-style=\"display-2\" data-app-selector=\".group-title\">\n\t\t\t\t\t\tSteaks\n\t\t\t\t\t</h3>\n\t\t\t\t\t<div class=\"row menu-row\" mbr-list mbr-list-grow=\"group5Items\" data-specials=\"{{specialsInGroup5}}\">\n\t\t\t\t\t\t<div class=\"col-md-12 menu-item\">\n\t\t\t\t\t\t\t<div class=\"special-label align-right\">\n\t\t\t\t\t\t\t\t<div mbr-text class=\"label-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".special-label\">Chef Selection</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<h3 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title\">Rack Of Lamb</h3>\n\t\t\t\t\t\t\t<div class=\"menu-box\">\n\t\t\t\t\t\t\t\t<p class=\"box-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".box-text\">\n\t\t\t\t\t\t\t\t\tLorem ipsum dolor sit amet, consectetur\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t<span mbr-text class=\"mbr-fonts-style box-price mbr-black\" mbr-theme-style=\"display-2\">\n\t\t\t\t\t\t\t\t\t$30\n\t\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"col-md-6\">\n\t\t\t\t<div class=\"menu-group\">\n\t\t\t\t\t<h3 class=\"mbr-fonts-style group-title mbr-black align-left\" mbr-theme-style=\"display-2\" data-app-selector=\".group-title\">\n\t\t\t\t\t\tPizza\n\t\t\t\t\t</h3>\n\t\t\t\t\t<div class=\"row menu-row\" mbr-list mbr-list-grow=\"group2Items\" data-specials=\"{{specialsInGroup2}}\">\n\t\t\t\t\t\t<div class=\"col-md-12 menu-item\">\n\t\t\t\t\t\t\t<div class