          "_name": "menu1",
          "_sourceTheme": "restaurantm4",
          "_customHTML": "<section class=\"menu menu1 restaurantm4_menu1\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n\n\t<mbr-parameters>\n\t\t<!-- Block parameters controls (Blue \"Gear\" panel) -->\n\t\t<header condition=\"showLogo || showIcons\">Size</header>\n\t\t<input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"3.8\" max=\"8\" step=\"0.1\" value=\"3.8\" condition=\"showLogo\">\n\t\t<select title=\"Icons\" name=\"iconsAmount\" condition=\"showIcons && showItems\">\n\t\t\t<option value=\"1\">1</option>\n\t\t\t<option value=\"2\">2</option>\n\t\t\t<option value=\"3\">3</option>\n\t\t\t<option value=\"4\" selected>4</option>\n\t\t\t<option value=\"5\">5</option>\n\t\t\t<option value=\"6\">6</option>\n\t\t</select>\n\t\t<header>Show / Hide</header>\n\t\t<input type=\"checkbox\" title=\"Logo\" name=\"showLogo\">\n\t\t<input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\" checked>\n\t\t<input type=\"checkbox\" title=\"Menu Items\" name=\"showItems\" checked>\n\t\t<input type=\"color\" title=\"Items Hover Color\" name=\"itemsHoverColor\" value=\"#cccccc\" condition=\"showItems\">\n\t\t<input type=\"checkbox\" title=\"Icons\" name=\"showIcons\" condition=\"showItems\">\n\n\t\t<input type=\"checkbox\" title=\"Button(s)\" name=\"showButtons\" condition=\"showItems\" checked>\n\t\t<input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n\t\t<input type=\"checkbox\" title=\"Collapsed\" name=\"collapsed\">\n\t\t<input type=\"checkbox\" title=\"Transparent\" name=\"transparent\">\n\t\t<input type=\"color\" title=\"Hamburger Color\" name=\"hamburgerColor\" value=\"#2aadd4\">\n\t\t<input type=\"color\" title=\"Background Color\" name=\"menuBgColor\" value=\"#ffffff\">\n\t\t<!-- End block parameters -->\n\t</mbr-parameters>\n\n\n\t<nav class=\"navbar navbar-dropdown\" mbr-class=\"{'navbar-fixed-top':sticky, 'navbar-expand-lg':!collapsed, 'collapsed':collapsed}\">\n\t\t<div class=\"navbar-brand\">\n\t\t\t<span mbr-if=\"showLogo\" class=\"navbar-logo\">\n\t\t\t\t<a href=\"https://mobiri.se\">\n\t\t\t\t\t<img src=\"@PROJECT_PATH@/assets/images/untitled-design.jpg\" alt=\"Mobirise\" mbr-style=\"{'height': logoSize + 'rem'}\">\n\t\t\t\t</a>\n\t\t\t</span>\n\t\t\t<span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-2\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove\"><a class=\"navbar-caption text-info\" data-app-selector=\".navbar-caption\" href=\"index.html\" data-app-placeholder=\"Type Text\">The Drunken Mermaid</a></span>\n\t\t</div>\n\t\t<button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\" mbr-if=\"showItems\">\n\t\t\t<div class=\"hamburger\">\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t</div>\n\t\t</button>\n\t\t<div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\n\t\t\t<ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-4\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish && !showBrand && !showLogo}\"><li class=\"nav-item\">\n\t\t\t\t\t<a class=\"nav-link link text-info\" href=\"page1.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">About</a>\n\t\t\t\t</li><li class=\"nav-item\"><a class=\"nav-link link text-info\" href=\"page1.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Menu</a></li>\n\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t<a class=\"nav-link link text-info\" href=\"https://mobiri.se\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Blog</a>\n\t\t\t\t</li>\n\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t<a class=\"nav-link link text-info\" href=\"https://mobiri.se\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Contact</a>\n\t\t\t\t</li></ul>\n\t\t\t<div class=\"icons-menu\" mbr-if=\"showIcons\">\n\t\t\t\t<a href=\"http://instagram.com\" target=\"_blank\">\n\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-instagram socicon\" style=\"color: rgb(85, 215, 254); fill: rgb(85, 215, 254);\"></span>\n\t\t\t\t</a>\n\t\t\t\t<a href=\"http://facebook.com\" target=\"_blank\" mbr-if=\"iconsAmount > 1\">\n\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-facebook socicon\" style=\"color: rgb(85, 215, 254); fill: rgb(85, 215, 254);\"></span>\n\t\t\t\t</a>\n\t\t\t\t<a href=\"http://youtube.com\" target=\"_blank\" mbr-if=\"iconsAmount > 2\">\n\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-youtube socicon\" style=\"color: rgb(85, 215, 254); fill: rgb(85, 215, 254);\"></span>\n\t\t\t\t</a>\n\t\t\t\t<a href=\"http://behance.com\" target=\"_blank\" mbr-if=\"iconsAmount > 3\">\n\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-behance socicon\" style=\"color: rgb(85, 215, 254); fill: rgb(85, 215, 254);\"></span>\n\t\t\t\t</a>\n\t\t\t\t<a href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 4\">\n\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-googleplus socicon\"></span>\n\t\t\t\t</a>\n\t\t\t\t<a href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 5\">\n\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-linkedin socicon\"></span>\n\t\t\t\t</a>\n\t\t\t</div>\n\t\t\t<div mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-buttons mbr-section-btn\"><a class=\"btn btn-sm btn-info\" href=\"tel:+1-757-222-2222\" data-app-placeholder=\"Type Text\">Call</a></div>\n\t\t</div>\n\t</nav>\n</section>",
          "_cid": "vd1qHMdSnq",
          "_anchor": "menu1-1",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "_name": "image2",
          "_customHTML": "<section class=\"image2\" group=\"Image & Video\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <select title=\"Align\" name=\"alignButtons\" condition=\"showButtons\">\n            <option value=\"justify-content-start\" selected>Left</option>\n            <option value=\"justify-content-center\">Center</option>\n            <option value=\"justify-content-end\">Right</option>\n        </select>\n        <input type=\"checkbox\" title=\"Description\" name=\"showDescription\" checked>\n        <header>Decoration</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"addTitleDec\" condition=\"showTitle\" checked>\n        <input type=\"color\" title=\"Color\" name=\"titleDecColor\" value=\"#33d5ad\" condition=\"addTitleDec\">\n        <input type=\"checkbox\" title=\"Button\" name=\"addBtnDec\" condition=\"showButtons\" checked>\n        <input type=\"color\" title=\"Color\" name=\"btnDecColor\" value=\"#33d5ad\" condition=\"addBtnDec\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\">\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/snackm5/components/_images/background1.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div class=\"container\">\n        <div class=\"row align-items-center\">\n            <div class=\"col-12 col-lg-4\">\n                <div class=\"text-wrapper\">\n                    <h3 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                        <span>\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 126 121\" fill=\"none\">\n                                <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M2.58298 3.09025C2.08298 5.00692 1.66631 6.96525 1.49964 8.92358C0.957977 15.8403 0.332979 39.0486 0.541312 43.7153C0.541312 45.1319 0.791311 46.7153 1.37464 48.0069C2.41631 50.2986 5.08298 50.4653 6.54131 48.3403C7.08298 47.5903 7.41631 46.5903 7.58298 45.6319C8.04131 42.8403 8.41631 40.0486 8.62464 37.2569C9.20797 28.8403 9.74964 20.3819 10.1246 11.9653C10.2496 9.17359 9.95797 6.34026 9.62464 3.54859C9.37464 1.46526 7.66631 -0.11808 6.08298 0.0069201C4.20798 0.173587 3.04131 1.38192 2.58298 3.09025ZM59.583 58.5897C59.7428 57.9507 59.8812 57.35 60.0134 56.7767L60.0134 56.7767C60.2949 55.5556 60.5477 54.4588 60.9163 53.3814C66.333 37.3814 75.0414 23.1314 84.958 9.58971C86.1247 8.00638 87.583 6.50638 89.208 5.50638C90.083 4.96471 91.833 5.04805 92.833 5.58972C93.583 6.00638 94.1247 7.63138 93.958 8.54805C93.6664 10.298 93.0414 12.0897 92.1664 13.6731C86.4164 24.1314 80.6247 34.5481 74.7497 44.9231C73.0215 47.9555 71.2168 50.9624 69.4154 53.9637C68.9149 54.7977 68.4146 55.6312 67.9163 56.4647C67.1663 57.7564 66.333 59.0064 65.458 60.1731C64.4997 61.5064 63.0413 62.2981 61.583 61.4231C61.491 61.367 61.3982 61.3125 61.3056 61.2582L61.3055 61.2581C60.4341 60.7466 59.583 60.2469 59.583 58.5897ZM118.583 120.633C117.915 120.521 117.209 120.419 116.481 120.314C115.033 120.104 113.498 119.882 112 119.549C103.125 117.549 94.2497 115.549 85.4163 113.466C83.4997 113.008 81.6247 112.216 79.9163 111.299C77.6247 110.091 76.833 108.383 77.208 106.508C77.583 104.633 79.083 103.466 81.708 103.424C83.4997 103.383 85.4164 103.424 87.1247 103.841C98.333 106.674 109.541 109.591 120.708 112.549C121.958 112.883 123.25 113.466 124.208 114.299C126.625 116.341 125.875 119.549 122.791 120.341C122.028 120.525 121.197 120.543 120.279 120.563H120.279H120.279C119.745 120.575 119.181 120.587 118.583 120.633Z\">\n                                </path>\n                            </svg>\n                            <b>About</b></span></h3>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">Founded in 2010, The Drunken Mermaid is the salt-soaked brainchild of a powerhouse mother-daughter duo. Combining a mother’s eye for hospitality with a daughter’s flair for tropical mischief, they’ve spent over a decade proving that the best stories are told with sand between your toes and a drink in your hand. <br><br>Check us out on Instagram!</p>\n                    <div class=\"button-container\">\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 191 195\" fill=\"none\">\n                            <path d=\"M188.259 168.622C188.613 169.648 188.558 170.772 188.104 171.759C187.651 172.746 186.835 173.52 185.826 173.922C184.294 174.445 182.631 174.441 181.102 173.91C179.254 173.333 177.455 172.613 175.72 171.756C173.66 